#!/usr/bin/expect -f
set timeout -1
spawn npx dotenv -e ../../.env -- npx drizzle-kit push

expect {
    "create column" {
        send "\r"
        exp_continue
    }
    "rename column" {
        send "\r"
        exp_continue
    }
    "Are you sure you want to proceed?" {
        send "y\r"
        exp_continue
    }
    "Is *" {
        send "\r"
        exp_continue
    }
    eof
}
